# Nexus Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# --- AI Provider API Keys ---
# At least one provider key is required for agent execution.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# --- Local Models (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Channel Tokens ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# --- Gateway ---
# NEXUS_DATA_DIR=~/.nexus
# NEXUS_UI_DIST=packages/ui/dist
